{
  "ci": {
    "collect": {
      "staticDistDir": "lhsite",
      "numberOfRuns": 3,
      "url": [
        "http://localhost/index.html",
        "http://localhost/docs/getting_started/installation/index.html",
        "http://localhost/docs/concepts/fundamentals/slots/index.html",
        "http://localhost/docs/reference/api/index.html"
      ]
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 1 }],
        "categories:seo": ["error", { "minScore": 1 }]
      }
    }
  }
}
