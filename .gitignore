# Project-specific files
sampleproject/staticfiles/
# Docs-site collectstatic output (the Lighthouse workflow assembles /static here)
docs_site/staticfiles/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
env/
build/
!docs_site/apps/docs/build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff:
*.log
*.sqlite3

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# VSCode
.vscode

# Poetry
# lock file is not needed for development
# as project supports variety of Django versions
poetry.lock

# PyCharm
.idea/

# Python environment
.venv/
.DS_Store
.python-version
site

# TEMPORARY (docs-migration PR): the committed historical doc-version snapshots
# (~15k files imported from gh-pages by `docs_import_ghpages`) are excluded from
# the migration PR so its diff is reviewable. They will be re-committed in a
# dedicated follow-up PR that removes this entry. Re-create locally with
# `docs_import_ghpages` if you need them on disk (they're still required for the
# multi-version deploy).
docs_site/versions/

.direnv/
.envrc
.mypy_cache/

# JS, NPM Dependency directories
node_modules/
jspm_packages/

# Cursor
.cursorrules
.codex

# Lighthouse CI local output (the workflow runs in ephemeral CI)
.lighthouseci/
